server {
    listen ${PORT};
    server_name _;
    root /usr/share/nginx/html;
    index index.html;

    # Reverse proxy API routes to the backend service
    location /api/ {
        proxy_pass https://${BACKEND_URL}/api/;
        proxy_set_header Host ${BACKEND_URL};
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Reverse proxy non-prefixed backend routes
    location /products { proxy_pass https://${BACKEND_URL}; proxy_set_header Host ${BACKEND_URL}; }
    location /customers { proxy_pass https://${BACKEND_URL}; proxy_set_header Host ${BACKEND_URL}; }
    location /vendors { proxy_pass https://${BACKEND_URL}; proxy_set_header Host ${BACKEND_URL}; }
    location /orders { proxy_pass https://${BACKEND_URL}; proxy_set_header Host ${BACKEND_URL}; }
    location /quotes { proxy_pass https://${BACKEND_URL}; proxy_set_header Host ${BACKEND_URL}; }
    location /invoices { proxy_pass https://${BACKEND_URL}; proxy_set_header Host ${BACKEND_URL}; }
    location /locations { proxy_pass https://${BACKEND_URL}; proxy_set_header Host ${BACKEND_URL}; }
    location /health { proxy_pass https://${BACKEND_URL}; proxy_set_header Host ${BACKEND_URL}; }
    location /activities { proxy_pass https://${BACKEND_URL}; proxy_set_header Host ${BACKEND_URL}; }
    location /contacts { proxy_pass https://${BACKEND_URL}; proxy_set_header Host ${BACKEND_URL}; }
    location /documents { proxy_pass https://${BACKEND_URL}; proxy_set_header Host ${BACKEND_URL}; }
    location /gl { proxy_pass https://${BACKEND_URL}; proxy_set_header Host ${BACKEND_URL}; }
    location /parsing { proxy_pass https://${BACKEND_URL}; proxy_set_header Host ${BACKEND_URL}; }
    location /price_levels { proxy_pass https://${BACKEND_URL}; proxy_set_header Host ${BACKEND_URL}; }
    location /pricing { proxy_pass https://${BACKEND_URL}; proxy_set_header Host ${BACKEND_URL}; }
    location /purchase-orders { proxy_pass https://${BACKEND_URL}; proxy_set_header Host ${BACKEND_URL}; }
    location /sales-team { proxy_pass https://${BACKEND_URL}; proxy_set_header Host ${BACKEND_URL}; }
    location /uploads { proxy_pass https://${BACKEND_URL}; proxy_set_header Host ${BACKEND_URL}; }

    # SPA fallback — send all non-file requests to index.html
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Cache static assets
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    # Gzip compression
    gzip on;
    gzip_types text/plain application/json application/javascript text/css application/xml text/javascript;
    gzip_min_length 256;
}
