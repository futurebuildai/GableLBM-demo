{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "DOCKER"
    },
    "deploy": {
        "numReplicas": 1,
        "sleepApplication": false
    },
    "services": {
        "backend": {
            "source": {
                "root": "backend"
            },
            "build": {
                "context": "backend",
                "dockerfilePath": "Dockerfile"
            }
        },
        "frontend": {
            "source": {
                "root": "app"
            },
            "build": {
                "context": "app",
                "dockerfilePath": "Dockerfile",
                "buildArgs": {
                    "VITE_API_URL": "https://backend-production-bdf8.up.railway.app"
                }
            }
        }
    }
}